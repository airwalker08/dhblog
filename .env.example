# Local development environment variables
DHBLOG_ENV=dev
# Uses machine-wide credentials (C:\ProgramData\AWS) when AWS_ACCESS_KEY_ID is unset
# Uses machine-wide credentials (C:\ProgramData\AWS) when AWS_ACCESS_KEY_ID is unset
AWS_REGION=us-west-2

# API
ASPNETCORE_ENVIRONMENT=Development
JWT_SECRET=local-dev-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRY_MINUTES=60

# Web (Vite)
VITE_API_URL=http://localhost:82

# Blog settings (local override when SSM unavailable)
blog_entry_text_len=250
blog_entry_max_img_count=10
blog_entry_max_img_types=png,jpg
blog_entry_max_img_size=1048576
site_name=dhblog
password_reset_token_ttl_minutes=30

# S3 (optional for local - use dev bucket or leave empty)
MEDIA_BUCKET_NAME=
CLOUDFRONT_MEDIA_DOMAIN=
